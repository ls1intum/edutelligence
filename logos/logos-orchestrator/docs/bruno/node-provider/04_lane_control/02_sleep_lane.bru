meta {
  name: Sleep Lane
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/logosdb/providers/logosnode/lanes/sleep
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "logos_key": "{{logosKey}}",
    "provider_id": "{{providerId}}",
    "lane_id": "{{laneId}}",
    "level": 1,
    "mode": "wait"
  }
}
