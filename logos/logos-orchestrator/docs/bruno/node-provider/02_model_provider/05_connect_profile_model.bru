meta {
  name: Connect Profile Model
  type: http
  seq: 5
}

post {
  url: {{baseUrl}}/logosdb/connect_profile_model
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "logos_key": "{{logosKey}}",
    "profile_id": "{{profileId}}",
    "model_id": "{{modelId}}"
  }
}
