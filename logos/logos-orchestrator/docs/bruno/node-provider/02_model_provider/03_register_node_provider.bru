meta {
  name: Register LogosWorkerNode Provider
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/logosdb/providers/logosnode/register
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "logos_key": "{{logosKey}}",
    "provider_name": "{{providerName}}",
    "base_url": ""
  }
}
