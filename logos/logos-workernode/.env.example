# ── Credentials (.env) ───────────────────────────────────────────────────────
# These are the ONLY settings in .env. Hardware and tuning live in config.yml.
# The server resolves provider_id and worker identity from the API key.

# Base URL of the Logos server (must be https:// in production).
LOGOS_URL=https://logos.example.com

# Provider API key (shared_key) returned by the registration endpoint.
# This is the only credential needed — the server identifies the worker from it.
LOGOS_API_KEY=

# DEV ONLY: set to "true" to allow connecting to an http:// Logos server.
LOGOS_ALLOW_INSECURE_HTTP=

# Maximum concurrent lanes. 0 or unset = unlimited (limited by port range/VRAM only).
MAX_LANES=

# ── tmpfs RAM cache ──────────────────────────────────────────────────────────
# Path to a tmpfs mount for caching model files in RAM (faster loading).
# Leave both empty to disable. When TMPFS_SIZE_BYTES is set, docker-compose
# mounts a tmpfs at /mnt/ramcache; the worker copies capabilities models there.
LOGOS_TMPFS_CACHE_PATH=/mnt/ramcache
# Size of the tmpfs mount in bytes. 0 or empty = disabled.
# Examples: 53687091200 = 50 GB, 107374182400 = 100 GB, 214748364800 = 200 GB
TMPFS_SIZE_BYTES=

# HuggingFace token for pulling gated models (e.g. google/gemma-3-12b-it).
# Create one at https://huggingface.co/settings/tokens (read access is sufficient).
HF_TOKEN=

# ── Docker image / build (dev only) ─────────────────────────────────────────

PYTHON_IMAGE=python:3.12-slim
INSTALL_OLLAMA=0
INSTALL_VLLM=1
VLLM_PIP_SPEC=vllm
NCCL_PIP_SPEC=nvidia-nccl-cu12==2.29.7
FLASHINFER_PIP_SPEC=
OLLAMA_MODELS_MOUNT=ollama-models
CUDA_HOME=/usr/local/cuda-12.8
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=utility,compute
