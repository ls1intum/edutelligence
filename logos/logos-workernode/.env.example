# Base image for the worker container.
PYTHON_IMAGE=python:3.12-slim

# Keep this at 1 unless you want to provide Ollama from somewhere else.
INSTALL_OLLAMA=0

# Local dev defaults to an Ollama-only image. Set to 1 for vLLM-capable builds.
INSTALL_VLLM=1

# Optional pip spec for vLLM when INSTALL_VLLM=1.
VLLM_PIP_SPEC=vllm

# Optional NCCL override for vLLM-capable builds.
NCCL_PIP_SPEC=nvidia-nccl-cu12==2.29.7

# Optional flashinfer override — useful for testing bugfix releases on Turing (SM 7.5).
# e.g. FLASHINFER_PIP_SPEC=flashinfer==0.6.7
FLASHINFER_PIP_SPEC=

# Named volume by default. Set an absolute host path to reuse host Ollama blobs.
OLLAMA_MODELS_MOUNT=ollama-models

# Only needed with docker-compose.gpu.yml.
CUDA_HOME=/usr/local/cuda-12.8
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=utility,compute
