# ── Logos server connection ──────────────────────────────────────────────────
# These three values are required for the worker to connect to the Logos server.
# Obtain provider_id and api_key by registering a logosnode provider via the
# Logos admin API (see docs/node-provider-setup.md, step 2).

# Base URL of the Logos server (must be https://).
LOGOS_URL=https://logos.example.com

# Numeric provider ID returned by the registration endpoint.
LOGOS_PROVIDER_ID=

# Provider API key (shared_key) returned by the registration endpoint.
LOGOS_API_KEY=

# Optional: stable worker identifier. Defaults to "worker-<provider_id>".
# Use a meaningful name when running multiple workers for the same provider.
LOGOS_WORKER_NODE_ID=

# DEV ONLY: set to "true" to allow connecting to an http:// Logos server.
# Never set this in production.
LOGOS_ALLOW_INSECURE_HTTP=

# ── Worker HTTP port ─────────────────────────────────────────────────────────
# Port the worker listens on (inside container and on localhost).
# Default is 80 (standard HTTP). Override for local dev to avoid port clashes.
# Only bound to 127.0.0.1 (localhost) — never exposed to the network.
WORKER_PORT=8444

# ── Docker image / build ─────────────────────────────────────────────────────

# Base image for the worker container.
PYTHON_IMAGE=python:3.12-slim

# Keep this at 1 unless you want to provide Ollama from somewhere else.
INSTALL_OLLAMA=0

# Local dev defaults to an Ollama-only image. Set to 1 for vLLM-capable builds.
INSTALL_VLLM=1

# Optional pip spec for vLLM when INSTALL_VLLM=1.
VLLM_PIP_SPEC=vllm

# Optional NCCL override for vLLM-capable builds.
NCCL_PIP_SPEC=nvidia-nccl-cu12==2.29.7

# Optional flashinfer override — useful for testing bugfix releases on Turing (SM 7.5).
# e.g. FLASHINFER_PIP_SPEC=flashinfer==0.6.7
FLASHINFER_PIP_SPEC=

# Named volume by default. Set an absolute host path to reuse host Ollama blobs.
OLLAMA_MODELS_MOUNT=ollama-models

# Only needed with docker-compose.gpu.yml.
CUDA_HOME=/usr/local/cuda-12.8
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=utility,compute
