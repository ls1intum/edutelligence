{
  "info": {
    "_postman_id": "logos-workernode-v2",
    "name": "LogosWorkerNode (Current)",
    "description": "Current LogosWorkerNode API collection (process + lane architecture).\n\nSetup:\n1. Start controller (`python -m logos_worker_node.main` or docker compose).\n2. Set base_url and api_key variables.\n3. Use /admin/lanes/apply for lane orchestration.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8444"
    },
    {
      "key": "api_key",
      "value": "RANDOM_DEFAULT_KEY"
    },
    {
      "key": "ollama_base_url",
      "value": "http://localhost:11435"
    },
    {
      "key": "model_name",
      "value": "qwen2.5:0.5b"
    },
    {
      "key": "lane_id",
      "value": "qwen2.5-coder_32b"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{api_key}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Public",
      "item": [
        {
          "name": "Root",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "url": "{{base_url}}/"
          }
        },
        {
          "name": "Health",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "url": "{{base_url}}/health"
          }
        }
      ]
    },
    {
      "name": "Status",
      "item": [
        {
          "name": "Node Status",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/status"
          }
        },
        {
          "name": "GPU",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/gpu"
          }
        },
        {
          "name": "Models Loaded",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/models/loaded"
          }
        },
        {
          "name": "Models Available",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/models/available"
          }
        },
        {
          "name": "Lanes (Status API)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/lanes"
          }
        },
        {
          "name": "Config",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/config"
          }
        }
      ]
    },
    {
      "name": "Admin Ollama",
      "item": [
        {
          "name": "Start",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/admin/ollama/start"
          }
        },
        {
          "name": "Stop",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/admin/ollama/stop"
          }
        },
        {
          "name": "Restart",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/admin/ollama/restart"
          }
        },
        {
          "name": "Reconfigure",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"num_parallel\": 8,\n  \"keep_alive\": \"10m\"\n}"
            },
            "url": "{{base_url}}/admin/ollama/reconfigure"
          }
        },
        {
          "name": "Destroy",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/admin/ollama/destroy"
          }
        }
      ]
    },
    {
      "name": "Admin Models",
      "item": [
        {
          "name": "Pull",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model\": \"{{model_name}}\"\n}"
            },
            "url": "{{base_url}}/admin/models/pull"
          }
        },
        {
          "name": "Pull Stream (NDJSON)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model\": \"{{model_name}}\"\n}"
            },
            "url": "{{base_url}}/admin/models/pull/stream"
          }
        },
        {
          "name": "Preload",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model\": \"{{model_name}}\"\n}"
            },
            "url": "{{base_url}}/admin/models/preload"
          }
        },
        {
          "name": "Unload",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model\": \"{{model_name}}\"\n}"
            },
            "url": "{{base_url}}/admin/models/unload"
          }
        },
        {
          "name": "Delete",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model\": \"{{model_name}}\"\n}"
            },
            "url": "{{base_url}}/admin/models/delete"
          }
        },
        {
          "name": "Show",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model\": \"{{model_name}}\"\n}"
            },
            "url": "{{base_url}}/admin/models/show"
          }
        }
      ]
    },
    {
      "name": "Admin Lanes",
      "item": [
        {
          "name": "Templates",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/admin/lanes/templates"
          }
        },
        {
          "name": "Apply",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"lanes\": [\n    {\n      \"model\": \"qwen2.5-coder:32b\",\n      \"backend\": \"ollama\",\n      \"num_parallel\": 8,\n      \"context_length\": 4096,\n      \"keep_alive\": \"10m\",\n      \"kv_cache_type\": \"q8_0\",\n      \"flash_attention\": true,\n      \"gpu_devices\": \"0\"\n    }\n  ]\n}"
            },
            "url": "{{base_url}}/admin/lanes/apply"
          }
        },
        {
          "name": "List",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/admin/lanes"
          }
        },
        {
          "name": "Events",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/admin/lanes/events?limit=100"
          }
        },
        {
          "name": "Get One",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/admin/lanes/{{lane_id}}"
          }
        },
        {
          "name": "Reconfigure One",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"num_parallel\": 16\n}"
            },
            "url": "{{base_url}}/admin/lanes/{{lane_id}}/reconfigure"
          }
        },
        {
          "name": "Delete One",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/admin/lanes/{{lane_id}}"
          }
        }
      ]
    },
    {
      "name": "Direct Inference (Bypass Controller)",
      "description": "Inference goes directly to backend ports. For single Ollama process mode, use ollama_base_url (default 11435).",
      "item": [
        {
          "name": "Ollama Version",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "url": "{{ollama_base_url}}/api/version"
          }
        },
        {
          "name": "Ollama Tags",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "url": "{{ollama_base_url}}/api/tags"
          }
        },
        {
          "name": "OpenAI Chat",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model\": \"{{model_name}}\",\n  \"messages\": [\n    { \"role\": \"user\", \"content\": \"Hello, what is 2+2?\" }\n  ],\n  \"stream\": false\n}"
            },
            "url": "{{ollama_base_url}}/v1/chat/completions"
          }
        }
      ]
    }
  ]
}
