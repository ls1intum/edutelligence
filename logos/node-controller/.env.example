# Node Controller environment variables
# Copy to .env and fill in values

# Docker image Python base
PYTHON_IMAGE=python:3.12-slim

# Install Ollama in the node-controller Docker image so Ollama lanes work
# without host binary mounts.
INSTALL_OLLAMA=1

# Install vLLM in the node-controller Docker image so vLLM lanes work out-of-the-box.
# Set to 0 if you explicitly want an Ollama-only lightweight image.
INSTALL_VLLM=1

# Optional pip spec for vLLM install (pin if needed).
# Example: VLLM_PIP_SPEC=vllm==0.8.5
VLLM_PIP_SPEC=vllm

# Where Ollama model blobs are persisted.
# Default uses a Docker named volume.
# To reuse host models, set an absolute host path, for example:
# OLLAMA_MODELS_MOUNT=/usr/share/ollama/.ollama/models
OLLAMA_MODELS_MOUNT=ollama-models
