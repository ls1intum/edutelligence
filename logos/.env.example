# Logos Docker Compose Environment Configuration
# Copy this file to .env and adjust for your environment.
#
# For local development, no .env file is needed — all variables
# have sensible defaults (localhost, self-signed TLS, no ACME).

# ── Domain ──────────────────────────────────────────────────
# The domain name used for Traefik routing rules.
# Default: localhost (for local development)
# Production example: logos.ase.cit.tum.de
LOGOS_DOMAIN=localhost

# ── TLS / ACME ──────────────────────────────────────────────
# Certificate resolver for Traefik TLS.
# Leave empty for self-signed certificates (local dev).
# Set to "letsencrypt" for automatic Let's Encrypt certificates (production).
LOGOS_CERT_RESOLVER=letsencrypt

# Email address used for Let's Encrypt ACME registration.
# Only relevant when LOGOS_CERT_RESOLVER=letsencrypt.
# Production example: ACME_EMAIL=your-email@tum.de
ACME_EMAIL=

# ── Prometheus Metrics ──────────────────────────────────────────────────────
# API key required to access /metrics. If unset, the metrics endpoint denies
# all requests. Pass the key via `Authorization: Bearer <key>` header.
PROMETHEUS_API_KEY=

# ── Internal service secret ───────────────────────────────────────────────────
# Shared secret between logos-webservice (Spring) and logos-orchestrator (Python).
# Spring sends this as `Authorization: Bearer <secret>` when calling the
# internal pipeline refresh endpoint. If unset, refresh notifications are
# silently skipped. Use any strong random string in production.
LOGOS_INTERNAL_SECRET=

# ── DEV ONLY ─────────────────────────────────────────────────────────────────
# Allow worker nodes to authenticate over plain HTTP (no TLS).
# Set to "true" for local development only. Never set in production.
LOGOS_NODE_DEV_ALLOW_INSECURE_HTTP=

# ── Keycloak (Logos auth) ─────────────────────────────────────────────────────
# Production: https://keycloak.aet.cit.tum.de/realms/tum
KEYCLOAK_ISSUER_URI=http://localhost:8085/realms/tum
# Public OIDC client id that the UI uses to talk to Keycloak.
KEYCLOAK_CLIENT_ID=logos
# Keycloak role names mapped to logos roles (comma-separated lists allowed)
KEYCLOAK_ROLES_LOGOS_ADMIN=itg-admin
KEYCLOAK_ROLES_APP_ADMIN=chair-member
# Role-name suffixes that mark a Keycloak role as a team (comma-separated).
# Keeps Keycloak's built-in roles (offline_access, uma_authorization, …) from
# becoming teams. Admin-linked teams (teams.keycloak_group) work regardless of suffix.
KEYCLOAK_TEAM_ROLE_SUFFIXES=-dev,-team,-group
# Background directory sync needs a service-account client; off until credentials exist.
# When enabling, set KEYCLOAK_SYNC_CLIENT_SECRET explicitly — no default is supplied
# so production deploys can't silently inherit a dev-only secret.
KEYCLOAK_SYNC_ENABLED=false
KEYCLOAK_SYNC_CLIENT_ID=logos-sync
KEYCLOAK_SYNC_CLIENT_SECRET=
# Note: the UI no longer reads EXPO_PUBLIC_KEYCLOAK_* — it pulls the Keycloak
# issuer and client id at runtime from the server's /api/info endpoint, which
# is populated from KEYCLOAK_ISSUER_URI and KEYCLOAK_CLIENT_ID above.
