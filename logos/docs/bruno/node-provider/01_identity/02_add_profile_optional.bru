meta {
  name: Add Profile (Optional)
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/logosdb/add_profile
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "logos_key": "{{logosKey}}",
    "profile_name": "node-demo-profile",
    "process_id": "{{processId}}"
  }
}
