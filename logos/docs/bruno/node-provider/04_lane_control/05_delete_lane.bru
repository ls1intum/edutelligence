meta {
  name: Delete Lane
  type: http
  seq: 5
}

post {
  url: {{baseUrl}}/logosdb/providers/logosnode/lanes/delete
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "logos_key": "{{logosKey}}",
    "provider_id": "{{providerId}}",
    "lane_id": "{{laneId}}"
  }
}
