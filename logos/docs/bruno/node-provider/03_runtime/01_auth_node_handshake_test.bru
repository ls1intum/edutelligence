meta {
  name: Auth Node (Handshake Test)
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/logosdb/providers/logosnode/auth
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "provider_id": "{{providerId}}",
    "shared_key": "{{sharedKey}}",
    "worker_id": "{{workerId}}",
    "capabilities_models": ["{{modelName}}"]
  }
}
